{
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "turbo format",
    "format:docs": "prettier --write \"docs/**/*.{md,mdx}\"",
    "format:docs:check": "prettier --check \"docs/**/*.{md,mdx}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "turbo": "^2.8.20",
    "typescript": "^6.0.2"
  },
  "name": "oxy",
  "packageManager": "pnpm@10.29.3",
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "@typescript-eslint/parser>typescript": "6",
        "@typescript-eslint/eslint-plugin>typescript": "6",
        "@typescript-eslint/utils>typescript": "6",
        "@typescript-eslint/type-utils>typescript": "6",
        "@typescript-eslint/project-service>typescript": "6",
        "@typescript-eslint/tsconfig-utils>typescript": "6",
        "@typescript-eslint/typescript-estree>typescript": "6",
        "vite-plugin-node-polyfills>vite": "8"
      }
    }
  }
}
